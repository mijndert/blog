---
title: Stats
summary: Some numbers about this blog.
layout: layouts/page.html
permalink: /stats/
---

<div class="stats-grid">
  <div class="proj-card">
    <h3 class="proj-name">Blog posts</h3>
    <div class="stat-number">{{ collections.blogposts | length }}</div>
  </div>
  <div class="proj-card">
    <h3 class="proj-name">Week notes</h3>
    <div class="stat-number">{{ collections.weeknotes | length }}</div>
  </div>
  <div class="proj-card">
    <h3 class="proj-name">Total posts</h3>
    <div class="stat-number">{{ collections.posts | length }}</div>
  </div>
  <div class="proj-card">
    <h3 class="proj-name">Topics</h3>
    <div class="stat-number">{{ collections.tagsList | length }}</div>
  </div>
  <div class="proj-card">
    <h3 class="proj-name">Words written</h3>
    <div class="stat-number">~{{ collections.posts | totalWords }}k</div>
  </div>
  <div class="proj-card">
    <h3 class="proj-name">Avg. words / post</h3>
    <div class="stat-number">{{ collections.blogposts | avgWords }}</div>
  </div>
  <div class="proj-card">
    <h3 class="proj-name">Reading time</h3>
    <div class="stat-number">{{ collections.posts | readingTime }}</div>
  </div>
</div>

<h2>Tags</h2>

<div class="tag-cloud">
{%- for item in collections.tagsList | topTags(collections.posts) -%}
  <span class="tag-pill">{{ item.tag }} <span class="tag-count">{{ item.count }}</span></span>
{%- endfor -%}
</div>

<h2>Posts per year</h2>

<div class="stats-grid">
{%- for item in collections.posts | postsPerYear -%}
  <div class="proj-card">
    <h3 class="proj-name">{{ item[0] }}</h3>
    <div class="stat-number">{{ item[1] }}</div>
  </div>
{%- endfor -%}
</div>

<h2>Posts by weekday</h2>

<div class="stats-grid">
{%- for item in collections.posts | postsByWeekday -%}
  <div class="proj-card">
    <h3 class="proj-name">{{ item.day }}</h3>
    <div class="stat-number">{{ item.count }}</div>
  </div>
{%- endfor -%}
</div>

<h2>Longest &amp; shortest post</h2>

{%- set longest = collections.blogposts | extremePost("longest") -%}
{%- set shortest = collections.blogposts | extremePost("shortest") -%}
<div class="stats-grid">
  <div class="proj-card">
    <h3 class="proj-name">Longest post</h3>
    <div class="stat-number">{{ longest.words }}</div>
    <div class="stat-sub">words · {{ longest.title }}</div>
  </div>
  <div class="proj-card">
    <h3 class="proj-name">Shortest post</h3>
    <div class="stat-number">{{ shortest.words }}</div>
    <div class="stat-sub">words · {{ shortest.title }}</div>
  </div>
</div>
